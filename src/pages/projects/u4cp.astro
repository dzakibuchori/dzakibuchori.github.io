---
import Layout from "../../layouts/Layout.astro";

const project = {
  title: "Unit4 CP (Compensation Planning)",
  image: "/projects/u4cp.webp",
  tags: ["Angular", "Spring Boot"],
  category: "Professional",
};
---

<Layout title={`${project.title} — Project`}>
  <div class="animate-fade-in">
    <section class="container py-10">
      <a href="/projects" class="hover:underline text-sm mb-6 inline-block">
        ← Back to Projects
      </a>

      <article class="glass-card overflow-hidden">
        <img
          src={project.image}
          alt={project.title}
          class="w-full max-h-96 object-contain rounded-xl"
        />
        <div class="p-8">
          <h1 class="text-3xl font-bold text-blue-950 dark:text-blue-100 mb-2">
            {project.title}
          </h1>
          <span
            class="text-xs font-medium px-2.5 py-0.5 rounded-full border w-fit mb-4 inline-block bg-purple-100 text-purple-700 border-purple-200 dark:bg-purple-900/40 dark:text-purple-300 dark:border-purple-700/50"
          >
            {project.category}
          </span>
          <div class="text-lg text-blue-900 dark:text-blue-200 mb-6">
            <p class="mb-4">
              This was the very first project I worked on after joining Unit4.
              It's enterprise-grade compensation planning application designed
              to help companies to plan, allocate, and communicate compensation
              decisions all within an easy to implement and intuitive
              application. The application supports everything from configuring
              multiple compensation plans, setting budgets and guidelines to
              automating recommendations and approvals, and <a
                href="https://www.unit4.com/sites/default/files/library-files/2022-03/Unit4-Human-Capital-Management-Compensation-Planning-FY220304INT.pdf"
                target="_blank"
                class="underline">much more</a
              >.
            </p>
            <h2 class="text-2xl font-bold mb-4">My key contributions:</h2>
            <p class="mb-4">
              <ul class="list-disc ml-4 mb-4">
                <li>
                  <strong
                    >Strengthened platform security, reliability, and compliance</strong
                  > by implementing HTTP Strict Transport Security (HSTS), securing
                  Application Insights configuration, enhancing Azure Service Bus
                  retry and reconnection logic, and conducting GDPR technical analysis
                  to identify hidden PII risks and implementation blockers.
                </li>
                <li>
                  <strong
                    >Improved observability and operational monitoring</strong
                  > by enhancing Application Insights logging across REST APIs, authentication
                  flows (login/logout), queue processing, and background jobs, significantly
                  improving issue traceability and production diagnostics.
                </li>
                <li>
                  <strong
                    >Stabilized and enhanced core analytics and planning modules</strong
                  > by fixing critical data accuracy, calculation, and UI issues across
                  modules: Pay Equity, Employee Analytics, Budget Rollup, Field Names
                  &amp; Locations, User Management and Role, ensuring reliable insights
                  and consistent user experience.
                </li>
                <li>
                  <strong
                    >Modernized backend architecture and improved code quality</strong
                  > through module refactoring (Department, Range Identifier, Data
                  Loader templates), increased unit test coverage (Dashboard and Report
                  utilities), and more resilient caching and tenant refresh mechanisms.
                </li>
                <li>
                  <strong
                    >Streamlined cloud infrastructure and CI/CD processes</strong
                  > by developing and maintaining Azure App Services deployment pipelines,
                  provisioning multiple QA environments, automating tenant secret
                  management with Azure Key Vault, and enhancing multi-tenant refresh
                  workflows.
                </li>
              </ul>

              <div class="flex flex-wrap gap-2">
                {
                  project.tags.map((tag) => (
                    <span class="glass-tag">{tag}</span>
                  ))
                }
              </div>
            </p>
          </div>
        </div>
      </article>
    </section>
  </div></Layout
>
