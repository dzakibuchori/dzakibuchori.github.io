---
import Layout from "../../layouts/Layout.astro";

const project = {
  title: "Unit4 CP (Compensation Planning)",
  image: "/projects/u4cp.webp",
  tags: ["Angular", "Spring Boot"],
  category: "Professional",
};
---

<Layout title={`${project.title} — Project`}>
  <div class="animate-fade-in">
    <section class="container py-10">
      <a href="/projects" class="hover:underline text-sm mb-6 inline-block">
        ← Back to Projects
      </a>

      <article class="glass-card overflow-hidden">
        <img
          src={project.image}
          alt={project.title}
          class="w-full max-h-96 object-contain rounded-xl"
        />
        <div class="p-8">
          <h1 class="text-3xl font-bold text-blue-950 dark:text-blue-100 mb-2">
            {project.title}
          </h1>
          <span
            class="text-xs font-medium px-2.5 py-0.5 rounded-full border w-fit mb-4 inline-block bg-purple-100 text-purple-700 border-purple-200 dark:bg-purple-900/40 dark:text-purple-300 dark:border-purple-700/50"
          >
            {project.category}
          </span>

          <p class="text-lg text-blue-900 dark:text-blue-200 mb-6">
            This was the very first project I worked on after joining Unit4.
            It's enterprise-grade compensation planning application designed to
            help companies to plan, allocate, and communicate compensation
            decisions all within an easy to implement and intuitive application.
            The application supports everything from configuring multiple
            compensation plans, setting budgets and guidelines to automating
            recommendations and approvals, and <a
              href="https://www.unit4.com/sites/default/files/library-files/2022-03/Unit4-Human-Capital-Management-Compensation-Planning-FY220304INT.pdf"
              target="_blank"
              class="underline">much more</a
            >.
          </p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => <span class="glass-tag">{tag}</span>)}
          </div>
        </div>
      </article>
    </section>
  </div>
</Layout>
