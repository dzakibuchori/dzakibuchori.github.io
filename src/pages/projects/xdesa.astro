---
import Layout from "../../layouts/Layout.astro";

const project = {
  title: "XDesa",
  description: "AI-powered smart village and management system",
  image: "/projects/xdesa.webp",
  tags: ["NextJs", "Go", "LiveKit"],
};
---

<Layout title={`${project.title} — Project`}>
  <div class="animate-fade-in">
    <section class="container py-10">
      <a
        href="/projects"
        class="text-purple-600 hover:underline text-sm mb-6 inline-block"
      >
        ← Back to Projects
      </a>

      <article class="glass-card overflow-hidden">
        <img
          src={project.image}
          alt={project.title}
          class="w-full max-h-96 object-cover rounded-t-xl"
        />
        <div class="p-8">
          <h1 class="text-3xl font-bold text-white mb-4">{project.title}</h1>
          <p class="text-lg text-blue-100 mb-6">{project.description}</p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => <span class="glass-tag">{tag}</span>)}
          </div>
        </div>
      </article>
    </section>
  </div>
</Layout>
