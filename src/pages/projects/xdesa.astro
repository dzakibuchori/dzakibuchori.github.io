---
import Layout from "../../layouts/Layout.astro";

const project = {
  title: "XDesa",
  description: "AI-powered smart village and management system",
  image: "/projects/xdesa.webp",
  tags: ["Next.js", "Go", "LiveKit"],
  category: "Personal",
};
---

<Layout title={`${project.title} — Project`}>
  <div class="animate-fade-in">
    <section class="container py-10">
      <a href="/projects" class="hover:underline text-sm mb-6 inline-block">
        ← Back to Projects
      </a>

      <article class="glass-card overflow-hidden">
        <img
          src={project.image}
          alt={project.title}
          class="w-full max-h-96 object-contain rounded-xl"
        />
        <div class="p-8">
          <h1 class="text-3xl font-bold text-blue-950 dark:text-blue-100 mb-2">
            {project.title}
          </h1>
          <span
            class="text-xs font-medium px-2.5 py-0.5 rounded-full border w-fit mb-4 inline-block bg-blue-100 text-blue-700 border-blue-200 dark:bg-blue-900/40 dark:text-blue-300 dark:border-blue-700/50"
          >
            {project.category}
          </span>
          <p class="text-lg text-blue-900 dark:text-blue-200 mb-6">
            {project.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => <span class="glass-tag">{tag}</span>)}
          </div>
        </div>
      </article>
    </section>
  </div>
</Layout>
