---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
const years = new Date().getFullYear() - 2018;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Dzaki Buchori",
  url: "https://dzakibuchori.github.io",
  image: "https://dzakibuchori.github.io/profile.jpg",
  jobTitle: "Full Stack Software Developer",
  worksFor: {
    "@type": "Organization",
    name: "Unit4",
  },
  sameAs: [
    "https://github.com/dzakibuchori",
    "https://linkedin.com/in/dzakibuchori",
  ],
  knowsAbout: ["Java", "TypeScript", "PHP", "Angular", "Spring Boot", "Next.js", "Go"],
};
---

<Layout
  title="Dzaki Buchori — Full Stack Software Developer"
  description={`Full Stack Software Developer with ${years}+ years of experience in Java, TypeScript, and PHP. Currently at Unit4 building enterprise-grade financial planning applications used by 400+ clients worldwide.`}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <section
    id="say-hi"
    class="flex flex-col sm:flex-row items-center gap-8 my-14 mx-8"
  >
    <!-- Profile Picture -->
    <div class="shrink-0">
      <img
        src="/profile.jpg"
        alt="Dzaki Buchori"
        class="w-28 h-28 sm:w-36 sm:h-36 lg:w-44 lg:h-44 rounded-full ring-2 ring-blue-900/20 dark:ring-white/30 shadow-[0_0_32px_rgba(66,153,225,0.35)] object-cover object-top hover:scale-105 transition-transform duration-300"
      />
    </div>
    <!-- Text Content -->
    <div class="flex-1 text-center sm:text-left">
      <h1 class="text-4xl font-bold mb-4 text-blue-950 dark:text-blue-100">
        👋 Hi, <br class="block md:hidden" />
        I'm Dzaki Buchori
      </h1>
      <div class="text-lg text-blue-900 dark:text-blue-200">
        <p class="mb-1">
          Currently working at <strong>Unit4</strong> as a <strong
            >Full Stack Developer</strong
          >, contributing to the web modernization of <strong
            >Unit4 Financial Planning & Analysis</strong
          >, an enterprise‑grade application used by <strong
            >400+ clients worldwide</strong
          >.
        </p>
      </div>
    </div>
  </section>

  <section id="about-me" class="container mb-8">
    <div class="glass-tab">
      <h2
        class="text-2xl font-semibold mb-2 text-blue-950 dark:text-blue-100 group-hover:text-white transition-colors"
      >
        About Me
      </h2>
    </div>
    <hr />
    <!-- Text Content -->
    <div class="flex-1 mt-4">
      <div class="text-lg text-blue-900 dark:text-blue-200">
        <p class="mb-2">
          Over the past <strong>{years} years</strong>, I've grown my career as
          a <strong>Full Stack Software Developer</strong>, working on complex,
          enterprise-scale web applications and leading technical teams along
          the way.
        </p>
        <p class="mb-2">
          I mainly worked with <strong>Java, Typescript, and PHP</strong>,
          building products across industries such as finance,
          telecommunications, government, education and e-commerce. My focus is
          on creating reliable, scalable solutions with AI as a natural part of
          my day-to-day work.
        </p>
        <!-- TODO: will reveal once about me content is ready 
        <a href="/about" class="underline">More about me...</a> -->
      </div>
    </div>
  </section>
  <section id="projects" class="container mb-8">
    <div class="glass-tab">
      <h2
        class="text-2xl font-semibold mb-2 text-blue-950 dark:text-blue-100 group-hover:text-white transition-colors"
      >
        Projects
      </h2>
    </div>
    <hr />
    <div class="flex-1 mt-4">
      <div class="text-lg text-blue-900 dark:text-blue-200">
        <p class="mb-2">
          My journey has taken me through a variety of projects, from personal
          experiments to full-scale professional work. I’m always curious,
          always looking for the next challenge that helps me grow. Here’s a
          snapshot of some of my most recent projects:
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 my-4">
          {projects.map((project) => <ProjectCard {...project} />)}
        </div>
        <a href="/projects" class="underline">View all projects...</a>
      </div>
    </div>
  </section>
</Layout>
