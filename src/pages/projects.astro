---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    title: "XDesa",
    description: "AI-powered smart village and management system",
    image: "/projects/xdesa.webp",
    tags: ["Next.js", "Go", "LiveKit"],
    link: "/projects/xdesa",
    category: "Personal",
  },
  {
    title: "Unit4 FP&A",
    description: "Enterprise-grade financial planning application",
    image: "/projects/u4fpa.webp",
    tags: ["Angular", "Java EE"],
    link: "/projects/u4fpa",
    category: "Professional",
  },
  {
    title: "Unit4 CP",
    description: "Enterprise-grade compensation planning application",
    image: "/projects/u4cp.webp",
    tags: ["Angular", "Spring Boot"],
    link: "/projects/u4cp",
    category: "Professional",
  },
];
---

<Layout title="Projects">
  <div class="animate-fade-in">
    <section class="container py-10">
      <div class="glass-tab">
        <h1
          class="text-2xl font-semibold mb-2 text-blue-950 dark:text-blue-100"
        >
          Projects
        </h1>
      </div>
      <hr />

      <div class="flex-1 mt-4">
        <p class="text-lg text-blue-900 dark:text-blue-200 mb-6">
          From government platforms to enterprise finance, these projects
          reflect the range of work I've built across my career as a Full Stack
          Developer — writing production code in <strong
            >Java, TypeScript, and PHP</strong
          >, and shipping across industries from telecommunications and
          education to e-commerce and financial services. Some are personal
          experiments where I reached for newer tools like <strong
            >Next.js, Go, and LiveKit</strong
          >; others are professional builds that demanded the reliability of <strong
            >Angular, Java EE, and Spring Boot</strong
          >.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            projects.map((project) => (
              <article class="glass-card overflow-hidden flex flex-col p-0">
                <img
                  src={project.image}
                  alt={project.title}
                  class="w-full h-48 object-cover rounded-t-xl"
                />
                <div class="p-6 flex flex-col flex-1">
                  <h2 class="text-xl font-semibold text-blue-950 dark:text-blue-100 mb-1">
                    {project.title}
                  </h2>
                  <span
                    class={`text-xs font-medium px-2.5 py-0.5 rounded-full border w-fit mb-3 ${
                      project.category === "Personal"
                        ? "bg-blue-100 text-blue-700 border-blue-200 dark:bg-blue-900/40 dark:text-blue-300 dark:border-blue-700/50"
                        : "bg-purple-100 text-purple-700 border-purple-200 dark:bg-purple-900/40 dark:text-purple-300 dark:border-purple-700/50"
                    }`}
                  >
                    {project.category}
                  </span>
                  <p class="text-sm mb-4 flex-1">{project.description}</p>
                  <div class="flex flex-wrap gap-2 mb-4">
                    {project.tags.map((tag) => (
                      <span class="glass-tag">{tag}</span>
                    ))}
                  </div>
                  <a href={project.link} class="underline text-sm">
                    View details...
                  </a>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</Layout>
