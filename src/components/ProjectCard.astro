---
import type { Project } from "../data/projects";

type Props = Project;

const { title, description, image, tags, link, category } = Astro.props;

const categoryClass =
  category === "Personal"
    ? "bg-blue-100 text-blue-700 border-blue-200 dark:bg-blue-900/40 dark:text-blue-300 dark:border-blue-700/50"
    : "bg-purple-100 text-purple-700 border-purple-200 dark:bg-purple-900/40 dark:text-purple-300 dark:border-purple-700/50";
---

<article class="glass-card overflow-hidden flex flex-col p-0">
  <img
    src={image}
    alt={title}
    class="w-full h-48 object-cover rounded-t-xl"
  />
  <div class="p-6 flex flex-col flex-1">
    <h3 class="text-lg font-semibold text-blue-950 dark:text-blue-100 mb-1">
      {title}
    </h3>
    <span
      class={`text-xs font-medium px-2.5 py-0.5 rounded-full border w-fit mb-3 ${categoryClass}`}
    >
      {category}
    </span>
    <p class="text-sm mb-4 flex-1">{description}</p>
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag) => <span class="glass-tag">{tag}</span>)}
    </div>
    <a href={link} class="underline text-sm">View details...</a>
  </div>
</article>
