---
type Props = {
  title: string;
  id?: string;
  headingLevel?: "h1" | "h2";
  class?: string;
};

const { title, id, headingLevel = "h2", class: className } = Astro.props;
---

<section id={id} class:list={["container", className ?? "mb-8"]}>
  <div class="glass-tab">
    {
      headingLevel === "h1" ? (
        <h1 class="text-2xl font-semibold mb-2 text-blue-950 dark:text-blue-100">
          {title}
        </h1>
      ) : (
        <h2 class="text-2xl font-semibold mb-2 text-blue-950 dark:text-blue-100">
          {title}
        </h2>
      )
    }
  </div>
  <hr />
  <div class="flex-1 mt-4">
    <slot />
  </div>
</section>
