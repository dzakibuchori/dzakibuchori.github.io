---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = "Personal website of Dzaki Buchori, a Software Engineer",
  ogImage = "/profile.jpg",
  ogType = "website",
} = Astro.props;

const siteURL = "https://dzakibuchori.github.io";
const canonicalURL = Astro.url.href;
const ogImageAbsolute = new URL(ogImage, siteURL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="Dzaki Buchori" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Per-page extras (e.g. JSON-LD, hreflang, etc.) -->
    <slot name="head" />

    <!-- Anti-FOUC: apply saved / OS theme before first paint -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body>
    <header id="site-header" class="fixed w-full z-50">
      <nav class="container mx-auto px-4 py-4 m-4">
        <div class="flex justify-between items-center">
          <!-- Logo -->
          <a
            href="/"
            aria-label="Dzaki Buchori Logo"
            class="flex items-center nav-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 109.21659 109.21661"
              class="h-8 w-8"
              fill="currentColor"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M 54.608555,1.9883854e-6 7.3805569e-7,54.608042 54.608035,109.2166 109.21658,54.608042 66.608335,11.999792 V 1.1988385e-5 Z m 0,15.7515000116146 v 77.71206 C 41.654613,80.512862 28.702164,67.560412 15.751497,54.606492 28.578175,41.777852 41.405063,28.947172 54.235965,16.124092 Z m 11.99978,11.99875 c 8.9525,8.95164 17.9053,17.90304 26.85625,26.85624 -8.95099,8.95365 -17.90373,17.90567 -26.85625,26.85779 z"
              ></path>
            </svg>
          </a>

          <!-- Right-side controls: nav + theme toggle + hamburger -->
          <div class="flex items-center gap-3">
            <!-- Desktop nav links -->
            <div class="hidden md:flex items-center space-x-6">
              <a href="/" class="nav-link">Home</a>
              <!-- TODO: will reveal once about me content is ready
              <a href="/about" class="nav-link">About Me</a> -->
              <!-- TODO: add view online functionality
              <a href="/resume" class="nav-link">Resume</a> -->
              <a href="/projects" class="nav-link">Projects</a>
              <!-- TODO: write minimum 5 contents for blog
              <a href="/blog" class="nav-link">Blog</a> -->
            </div>

            <!-- Theme toggle button (always visible) -->
            <button
              id="theme-toggle"
              aria-label="Toggle light/dark mode"
              class="cursor-pointer nav-link p-2 rounded-lg transition-all"
            >
              <!-- Moon: shown in light mode — click to switch to dark -->
              <svg
                id="icon-moon"
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
                ></path>
              </svg>
              <!-- Sun: shown in dark mode — click to switch to light -->
              <svg
                id="icon-sun"
                class="hidden w-5 h-5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0z"
                ></path>
              </svg>
            </button>

            <!-- Mobile hamburger (hidden on desktop) -->
            <button
              class="md:hidden nav-link"
              id="mobile-menu-button"
              aria-label="Toggle menu"
              aria-expanded="false"
            >
              <!-- Hamburger icon -->
              <svg
                id="icon-hamburger"
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
              <!-- Close (X) icon -->
              <svg
                id="icon-close"
                class="hidden w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>
      </nav>

      <!-- Mobile menu panel -->
      <div
        id="mobile-menu"
        class="hidden md:hidden border-t border-[color:var(--color-border-subtle)]"
      >
        <div class="container mx-auto px-4 py-2 flex flex-col">
          <a
            href="/"
            class="nav-link py-3 border-b border-[color:var(--color-border-subtle)]"
            >Home</a
          >
          <!-- TODO: will reveal once about me content is ready
          <a
            href="/about"
            class="nav-link py-3 border-b border-[color:var(--color-border-subtle)]"
            >About Me</a
          > -->
          <!-- TODO: add view online functionality
          <a
            href="/resume"
            class="nav-link py-3 border-b border-[color:var(--color-border-subtle)]"
            >Resume</a
          > -->
          <a
            href="/projects"
            class="nav-link py-3 border-b border-[color:var(--color-border-subtle)]"
            >Projects</a
          >
          <!-- TODO: write minimum 5 contents for blog
          <a href="/blog" class="nav-link py-3">Blog</a> -->
        </div>
      </div>
    </header>

    <main class="container mx-auto px-4 pt-24 pb-12">
      <div class="animate-fade-in">
        <slot />
      </div>
    </main>

    <footer class="mb-4">
      <div class="container mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row justify-between items-center">
          <div class="nav-link opacity-70 text-sm">
            © {new Date().getFullYear()} Dzaki Buchori. All rights reserved.
          </div>
          <div class="flex space-x-4 mt-4 md:mt-0">
            <a
              href="https://github.com/dzakibuchori"
              class="nav-link"
              aria-label="GitHub"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path></svg
              >
            </a>
            <a
              href="https://linkedin.com/in/dzakibuchori"
              class="nav-link"
              aria-label="LinkedIn"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                ></path></svg
              >
            </a>
            <a
              href="mailto:dzakibuchori.dev@gmail.com"
              class="nav-link"
              aria-label="Email"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <rect
                  width="20"
                  height="16"
                  x="2"
                  y="4"
                  rx="2"
                  stroke="currentColor"
                  fill="none"></rect>
                <path d="M22 6 12 13 2 6" stroke="currentColor" fill="none"
                ></path>
              </svg>
            </a>
            <a
              href="https://dzakibuchori.github.io"
              class="nav-link"
              aria-label="Website"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <circle cx="12" cy="12" r="10" stroke="currentColor" fill="none"
                ></circle>
                <ellipse
                  cx="12"
                  cy="12"
                  rx="4"
                  ry="10"
                  stroke="currentColor"
                  fill="none"></ellipse>
                <path d="M2 12h20" stroke="currentColor"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // ── Scroll: glass header effect ────────────────────────────────────────
      const header = document.getElementById("site-header");
      const menuButton = document.getElementById("mobile-menu-button");
      const mobileMenu = document.getElementById("mobile-menu");
      const iconHamburger = document.getElementById("icon-hamburger");
      const iconClose = document.getElementById("icon-close");

      window.addEventListener(
        "scroll",
        () => {
          if (header) {
            header.classList.toggle("glass-header", window.scrollY > 10);
          }
        },
        { passive: true },
      );

      // ── Mobile menu ────────────────────────────────────────────────────────
      function openMenu() {
        mobileMenu?.classList.remove("hidden");
        iconHamburger?.classList.add("hidden");
        iconClose?.classList.remove("hidden");
        menuButton?.setAttribute("aria-expanded", "true");
        header?.classList.add("glass-header");
      }

      function closeMenu() {
        mobileMenu?.classList.add("hidden");
        iconHamburger?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
        menuButton?.setAttribute("aria-expanded", "false");
        if (window.scrollY <= 10) {
          header?.classList.remove("glass-header");
        }
      }

      menuButton?.addEventListener("click", () => {
        const isOpen = !mobileMenu?.classList.contains("hidden");
        isOpen ? closeMenu() : openMenu();
      });

      mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMenu);
      });

      // ── Theme toggle ───────────────────────────────────────────────────────
      const themeToggle = document.getElementById("theme-toggle");
      const iconMoon = document.getElementById("icon-moon");
      const iconSun = document.getElementById("icon-sun");

      function applyThemeIcons(isDark: boolean) {
        iconMoon?.classList.toggle("hidden", isDark);
        iconSun?.classList.toggle("hidden", !isDark);
      }

      // Sync icons with the theme the anti-FOUC script already applied
      applyThemeIcons(document.documentElement.classList.contains("dark"));

      themeToggle?.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        applyThemeIcons(isDark);
      });
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: system-ui, sans-serif;
  }
  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }
</style>
